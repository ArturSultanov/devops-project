apiVersion: v1
kind: Namespace
metadata:
  name: devops-demo--wordpress
spec: {}
status: {}
---
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: gp3
parameters:
  fsType: ext4
  type: gp3
provisioner: ebs.csi.aws.com
reclaimPolicy: Retain
volumeBindingMode: WaitForFirstConsumer
---
apiVersion: v1
data:
  MYSQL_ROOT_PASSWORD: U3VwZXJTZWNyZXRSb290MTIzIQ==
  MYSQL_USER_PASSWORD: V3BVc2VyUGFzczQ1NiE=
kind: Secret
metadata:
  name: mysql-secret-td27mgg25g
  namespace: devops-demo--wordpress
type: Opaque
---
apiVersion: v1
kind: Service
metadata:
  labels:
    app: mysql
  name: mysql
  namespace: devops-demo--wordpress
spec:
  ports:
  - port: 3306
    targetPort: 3306
  selector:
    app: mysql
  type: ClusterIP
---
apiVersion: v1
kind: Service
metadata:
  labels:
    app: mysql
  name: mysql-headless
  namespace: devops-demo--wordpress
spec:
  clusterIP: None
  ports:
  - port: 3306
    targetPort: 3306
  selector:
    app: mysql
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  labels:
    app: mysql
  name: mysql
  namespace: devops-demo--wordpress
spec:
  podManagementPolicy: OrderedReady
  replicas: 1
  selector:
    matchLabels:
      app: mysql
  serviceName: mysql-headless
  template:
    metadata:
      labels:
        app: mysql
    spec:
      containers:
      - env:
        - name: MYSQL_DATABASE
          value: wordpress
        - name: MYSQL_ROOT_PASSWORD
          valueFrom:
            secretKeyRef:
              key: MYSQL_ROOT_PASSWORD
              name: mysql-secret-td27mgg25g
        - name: MYSQL_USER
          value: wordpress
        - name: MYSQL_PASSWORD
          valueFrom:
            secretKeyRef:
              key: MYSQL_USER_PASSWORD
              name: mysql-secret-td27mgg25g
        image: public.ecr.aws/bitnami/mysql:9.6-debian-12
        imagePullPolicy: IfNotPresent
        livenessProbe:
          exec:
            command:
            - /bin/bash
            - -c
            - mysqladmin ping -h localhost -u root --password="$MYSQL_ROOT_PASSWORD"
              --silent
          failureThreshold: 5
          periodSeconds: 10
          timeoutSeconds: 5
        name: mysql
        ports:
        - containerPort: 3306
        readinessProbe:
          exec:
            command:
            - /bin/bash
            - -c
            - mysql -h localhost -u root --password="$MYSQL_ROOT_PASSWORD" -e "SELECT
              1;" --silent
          failureThreshold: 3
          periodSeconds: 5
          timeoutSeconds: 3
        resources:
          requests:
            cpu: 250m
            memory: 512Mi
        startupProbe:
          exec:
            command:
            - /bin/bash
            - -c
            - mysqladmin ping -h localhost -u root --password="$MYSQL_ROOT_PASSWORD"
              --silent
          failureThreshold: 30
          initialDelaySeconds: 30
          periodSeconds: 10
        volumeMounts:
        - mountPath: /bitnami/mysql/data
          name: mysql-data
      terminationGracePeriodSeconds: 60
  updateStrategy:
    rollingUpdate:
      maxUnavailable: 1
    type: RollingUpdate
  volumeClaimTemplates:
  - metadata:
      labels:
        app: mysql
      name: mysql-data
    spec:
      accessModes:
      - ReadWriteOnce
      resources:
        requests:
          storage: 20Gi
      storageClassName: gp3
